# HelioSense environment variables
# Copy this file to .env and fill in your real keys.

# OpenUV API key used by /api/uv and /api/uv-detail
OPENUV_API_KEY=your_openuv_api_key_here

# Google Gemini API key used by /api/chat
# If left empty, the app will use built-in fallback responses.
GEMINI_API_KEY=your_gemini_api_key_here

# Local server port (optional)
PORT=3000
